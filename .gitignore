# Obsidian local-only state — don't sync workspace UI between machines
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/plugins/*/data.json

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
*.swp

# Temp / scratch artifacts
_scratch/.tmp/
*.tmp
*.bak

# Bulk-imported binaries (Downloads + Documents → _imports/).
# Keep the .md sidecars (frontmatter + extracted excerpt) in git so the
# vault is searchable, but exclude the source binaries — they're 240+ MB
# of PDFs/Office docs that bloat the pack history and don't need to live
# on GitHub. Originals stay on disk at C:\Users\…\Downloads / Documents.
_imports/**/*.pdf
_imports/**/*.docx
_imports/**/*.doc
_imports/**/*.xlsx
_imports/**/*.xls
_imports/**/*.pptx
_imports/**/*.ppt
_imports/**/*.rtf
_imports/**/*.odt
_imports/**/*.ods
_imports/**/*.odp

# Office lockfiles (~$foo.docx) sometimes get swept in by bulk copies.
~$*

# >100MB — GitHub hard limit; kept on disk only
_knowledge/downloads/files/Archives/net8.0-windows.zip
_knowledge/downloads/files/Video/Showcase Your AI Skills_ Join Our Summit!.mp4
