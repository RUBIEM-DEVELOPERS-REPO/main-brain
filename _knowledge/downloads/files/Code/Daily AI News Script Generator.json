    {
      "parameters": {
        "promptType": "define",
        "text": "=Search for AI news published TODAY ({{ $('Workflow Configuration').item.json.currentDate }}).\n\nSearch for:\n- AI breakthroughs and research announcements\n- New AI product launches and updates\n- Industry developments and partnerships\n- AI policy and regulation news\n- Notable AI applications and use cases\n\n\nFor each news item found, extract:\n- Title\n- Source\n- Publication date/time\n- Brief summary (2-3 sentences)\n- Significance/impact\n- URL\n\nReturn your findings in the structured format with newsItems array, totalFound count, and searchDate.",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an AI news research agent. Your task is to search for and gather the most significant AI news published TODAY with as minimal searches possible. Focus on reputable sources like TechCrunch, VentureBeat, MIT Technology Review, The Verge, Ars Technica, AI research labs, and major tech companies. Prioritize the top 3 most significant stories. If multiple sources report the same story, consolidate them into one entry with multiple source citations.",
          "maxIterations": 100
        }
      },
      "id": "23a7d701-f2be-4aa0-84ef-aefedc74a3a4",
