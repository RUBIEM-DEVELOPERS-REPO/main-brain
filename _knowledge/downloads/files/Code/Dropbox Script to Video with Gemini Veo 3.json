    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n\t\"type\": \"object\",\n\t\"properties\": {\n\t\t\"visualQuality\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Assessment of visual quality\"\n\t\t},\n\t\t\"pacingAndTiming\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Evaluation of video pacing\"\n\t\t},\n\t\t\"contentClarity\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Analysis of content clarity\"\n\t\t},\n\t\t\"technicalImprovements\": {\n\t\t\t\"type\": \"array\",\n\t\t\t\"items\": {\n\t\t\t\t\"type\": \"string\"\n\t\t\t},\n\t\t\t\"description\": \"List of technical suggestions\"\n\t\t},\n\t\t\"priorityLevel\": {\n\t\t\t\"type\": \"string\",\n\t\t\t\"description\": \"Overall priority: high, medium, or low\"\n\t\t},\n\t\t\"specificEnhancements\": {\n\t\t\t\"type\": \"array\",\n\t\t\t\"items\": {\n\t\t\t\t\"type\": \"string\"\n\t\t\t},\n\t\t\t\"description\": \"Actionable enhancement recommendations\"\n\t\t}\n\t}\n}",
        "autoFix": true
